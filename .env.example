# Supabase baglanti bilgileri (remote)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase baglanti bilgileri (local)
# Local backend calistiginda URL sabittir: http://127.0.0.1:54321
# Anon key degeri icin: npm run supabase:status
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_ANON_KEY=local-anon-key-from-supabase-status

# Google Gemini API - AI Tarayici modulu icin
# Edinmek icin: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your-gemini-api-key
